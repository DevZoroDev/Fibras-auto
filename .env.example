# Copia este archivo como ".env" y completa los valores.
# NOTA: la planilla y la ciudad ahora también se pueden configurar DESDE LA APP
# (botón "⚙ Configuración" y selector de ciudad); esos ajustes se guardan en
# config_local.json y tienen prioridad sobre lo que pongas aquí.

# Ruta al ID de cliente OAuth (tipo "App de escritorio"), descargado desde
# Google Cloud Console. La app inicia sesión con TU cuenta de Gmail.
GOOGLE_CREDENTIALS_PATH=credentials.json

# Token de usuario cacheado tras el primer login (se crea solo).
GOOGLE_TOKEN_PATH=token.json

# ID de la planilla por defecto (opcional; puedes enlazarla desde la app).
# Está en la URL: https://docs.google.com/spreadsheets/d/<ESTE_ES_EL_ID>/edit
GOOGLE_SHEET_ID=

# (Opcional) Ruta al ejecutable de Tesseract. Déjalo vacío si está en el PATH
# o si usas la versión portable (Tesseract embebido junto al .exe).
# Windows: C:\Program Files\Tesseract-OCR\tesseract.exe
TESSERACT_CMD=
