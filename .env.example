# Copia este archivo como ".env" y completa los valores.

# Ruta al archivo JSON de la cuenta de servicio de Google.
# (descargado desde Google Cloud Console)
GOOGLE_CREDENTIALS_PATH=credentials.json

# ID de la planilla de Google Sheets.
# Está en la URL: https://docs.google.com/spreadsheets/d/<ESTE_ES_EL_ID>/edit
GOOGLE_SHEET_ID=

# Nombre de la pestaña (hoja) donde se escribirán las filas.
GOOGLE_WORKSHEET_NAME=Solicitudes

# (Opcional) Ruta al ejecutable de Tesseract.
# En macOS con Homebrew suele ser /opt/homebrew/bin/tesseract
# En Windows suele ser C:\Program Files\Tesseract-OCR\tesseract.exe
# Déjalo vacío si tesseract está en el PATH del sistema.
TESSERACT_CMD=

# Tienda fija para todas las solicitudes.
TIENDA=Iquique
